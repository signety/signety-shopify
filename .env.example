# Shopify app environment variables
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SCOPES=read_orders,write_orders,read_products,write_products,read_fulfillments
SHOPIFY_APP_URL=https://shopify.signety.co

# SQLite database (local file, NOT the main Signety PostgreSQL — MED-10)
DATABASE_URL=file:./prisma/data.db

# Signety API (set after creating API key in Signety dashboard)
SIGNETY_API_URL=https://api.signety.co/api/v1/sdk
